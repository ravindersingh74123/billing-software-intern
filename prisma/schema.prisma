generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}



model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String

  customers Customer[]
  items Item[]
  invoices  Invoice[] 
  transactions Transaction[]
  portfolioSettings CryptoPortfolioSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id             String   @id @default(uuid())

  // relation
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // basic info
  companyName    String?
  displayName    String
  primaryContact String?
  email          String?

  // tax details
  pan            String?
  gstin          String?

  // address
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  pincode        String?

  // bank details
  bankName       String?
  accountName    String?
  accountNumber  String?
  ifsc           String?

  invoices       Invoice[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model Item {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  price       Float
  unit        String?
  description String?

  gstRate     Float?   // e.g. 5, 12, 18
  hsn         String?   // keep as string

  invoiceItems InvoiceItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Invoice {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  invoiceNo   String   @unique
  issueDate   DateTime @default(now())

  totalAmount Float

  items       InvoiceItem[]   // ✅ relation

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model InvoiceItem {
  id        String  @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  itemId    String?
  item      Item?   @relation(fields: [itemId], references: [id])

  name      String
  price     Float
  quantity  Int

  taxableAmount Float?
  gstRate       Float?
  gstAmount     Float?
  total         Float?
}

model Transaction {
  id              String   @id @default(uuid())

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            String   // "BUY" | "SELL"
  coin            String
  quantity        Float
  price           Float
  fee             Float
  date            DateTime

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model CryptoPortfolioSettings {
  id            String   @id @default(cuid())
  userId        String   @unique

  taxRate       Float    @default(30)
  tdsRate       Float    @default(1)
  currentPrices Json     @default("{}")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}